<RelativeLayout
    android:id="@+id/rootLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/home_bg">

    <!-- 🔥 HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#0D1B2A">

        <!-- TOP BAR -->
        <RelativeLayout
            android:layout_width="200dp"
            android:layout_height="60dp">

            <ImageView
                android:id="@+id/appLogo"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_alignParentStart="true"
                android:layout_marginStart="3dp"
                android:src="@drawable/app_logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:layout_toRightOf="@+id/appLogo"
                android:text="LOREXA"
                android:textColor="#F4B942"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <!-- SEARCH -->
        <EditText
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/search_bg"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="10dp"
            android:hint="Search historical figures..."
            android:paddingStart="16dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#A0A0A0"
            android:layout_marginBottom="12dp"/>

        <!-- CATEGORY CHIPS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/btnAll"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="ALL"
                    android:textColor="#1A1A1A"
                    android:background="@drawable/gold_button_bg"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnScientists"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Scientists"
                    android:textColor="#1A1A1A"
                    android:backgroundTint="@null"
                    android:background="@drawable/gold_button_bg"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/btnPhilosophers"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Philosophers"
                    android:textColor="#1A1A1A"
                    android:backgroundTint="@null"
                    android:background="@drawable/gold_button_bg"
                    android:gravity="center"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    android:layout_marginEnd="8dp"/>

            </LinearLayout>

        </HorizontalScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_above="@id/footer"
        android:padding="8dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"/>


    <LinearLayout
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:background="#0D1B2A"
        android:gravity="center">

        <!-- HOME -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/homeBtn"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="#F4B942"/>

            <TextView
                android:text="Home"
                android:textSize="10sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F4B942"/>
        </LinearLayout>

        <!-- CHAT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/chatBtn"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_chat"
                app:tint="#FFFFFF"/>

            <TextView
                android:text="Chats"
                android:textSize="10sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- PROFILE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/profileBtn"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="#FFFFFF"/>

            <TextView
                android:text="Profile"
                android:textSize="10sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"/>

        </LinearLayout>

        <!-- SETTINGS -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/settingsBtn"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_settings"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Settings"
                android:textSize="10sp"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>